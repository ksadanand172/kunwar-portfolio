{
  "version": 2,
  "public": true,
  "routes": [
    {
      "src": "/hero.mp4",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable",
        "Accept-Ranges": "bytes",
        "Content-Type": "video/mp4"
      }
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}