{
  "version": 2,
  "routes": [
    {
      "src": "/hero.mp4",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable",
        "Accept-Ranges": "bytes",
        "Content-Type": "video/mp4"
      },
      "dest": "/public/hero.mp4"
    },
    {
      "src": "/favicon.png",
      "dest": "/public/favicon.png"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.html"
    }
  ]
}