{
  "buildCommand": "",
  "outputDirectory": "public",
  "routes": [
    {
      "src": "/hero.mp4",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable",
        "Accept-Ranges": "bytes",
        "Content-Type": "video/mp4"
      }
    },
    {
      "src": "/favicon.png",
      "headers": {
        "Cache-Control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}